# ===== BACKEND CORE =====
ENVIRONMENT=development
DEBUG=true
API_PORT=8000
API_HOST=0.0.0.0

# ===== DATABASE =====
# Local MVP default. Use PostgreSQL in production, e.g.:
# postgresql://trendhunter:trendhunter@postgres:5432/trendhunter
# Railway production backend:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=sqlite:///./trendhunter.db
DATABASE_ECHO=false
AUTO_CREATE_TABLES=true

# ===== REDIS =====
REDIS_URL=redis://redis:6379/0

# ===== QDRANT VECTOR DB =====
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=trends

# ===== LLM PROVIDERS =====
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# ===== AUTHENTICATION =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-secret-key
JWT_SECRET=your-jwt-secret-change-in-production

# ===== BILLING =====
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_test_your-key

# ===== EXTERNAL SERVICES =====
# Reddit API
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USER_AGENT=TrendHunter/1.0

# Product Hunt API
PRODUCTHUNT_TOKEN=your-api-token

# Hacker News API (public, no key needed)
HACKERNEWS_API_URL=https://hacker-news.firebaseio.com/v0
HACKERNEWS_DEFAULT_LIMIT=20

# YouTube API
YOUTUBE_API_KEY=your-api-key

# GitHub API
GITHUB_TOKEN=your-personal-access-token

# NewsAPI (for news aggregation)
NEWSAPI_KEY=your-api-key

# RSS/Feed Parser
RSS_CHECK_INTERVAL=3600

# ===== EMAIL =====
RESEND_API_KEY=re_your-key-here
SENDER_EMAIL=noreply@trendhunter.io

# ===== ANALYTICS =====
PLAUSIBLE_DOMAIN=trendhunter.io
ANALYTICS_ENABLED=true

# ===== SECURITY =====
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== FRONTEND =====
# Railway production frontend:
# NEXT_PUBLIC_API_URL=https://${{trendhunter-backend.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# ===== FEATURES =====
ENABLE_AGENT_SCHEDULING=true
ENABLE_VECTOR_SEARCH=true
ENABLE_PDF_REPORTS=true
ENABLE_SLACK_ALERTS=false

# ===== CELERY QUEUE =====
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4

# ===== DATA RETENTION =====
TREND_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30
SESSION_TIMEOUT_MINUTES=1440

# ===== RATE LIMITING =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ===== AGENT CONFIG =====
AGENT_EXECUTION_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_BATCH_SIZE=50

# ===== OBSERVABILITY =====
LOG_LEVEL=INFO
SENTRY_DSN=
ENABLE_STRUCTURED_LOGGING=true

# ===== DEVELOPMENT =====
MOCK_LLM_RESPONSES=false
SEED_DATABASE=false
